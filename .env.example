# ================================
# Database Configuration
# ================================

# PostgreSQL database name
POSTGRES_DB=change_me_db

# Database user
POSTGRES_USER=change_me_user

# Database password (change in production)
POSTGRES_PASSWORD=change_me

# Root path for storing uploaded files
STORAGE_ROOT_PATH=/app/uploads


# ================================
# JWT Authentication
# ================================

# Secret key used to sign tokens (use a long random string in production)
JWT_KEY=change_me_to_a_long_random_secret_key

# Token issuer (backend service name)
JWT_ISSUER=TranscendenceApi

# Token audience (client application)
JWT_AUDIENCE=TranscendenceFrontend

# Token expiration time (in minutes)
JWT_EXPIRY_MINUTES=60


# ================================
# Google Authentication
# ================================

# Google OAuth Client ID (must match frontend config)
GOOGLE_CLIENTID=your_google_client_id_here