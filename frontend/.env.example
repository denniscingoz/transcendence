# ================================
# Frontend Configuration (Vite)
# ================================

# Use mock data instead of real API
VITE_USE_MOCKS=false

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Base API URL (proxied via Vite or Nginx)
VITE_API_BASE_URL=/api


# ================================
# Database Configuration
# ================================

# PostgreSQL database name
POSTGRES_DB=trans_db

# PostgreSQL user
POSTGRES_USER=postgres

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=change_me

# Path where uploaded files are stored
STORAGE_ROOT_PATH=/app/uploads


# ================================
# JWT Authentication
# ================================

# Secret key used to sign JWT tokens (use a long random string)
JWT_KEY=change_me_to_a_long_random_secret_key

# Token issuer (usually your backend service name)
JWT_ISSUER=TranscendenceApi

# Token audience (frontend or client app)
JWT_AUDIENCE=TranscendenceFrontend

# Token expiration time (in minutes)
JWT_EXPIRY_MINUTES=60


# ================================
# Google Authentication (Backend)
# ================================

# Google OAuth Client ID (must match frontend)
GOOGLE_CLIENT_ID=your_google_client_id_here